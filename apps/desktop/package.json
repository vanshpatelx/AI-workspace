{
  "name": "@ai-workspace/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "connect": "tsx src/connect.ts",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "electron .",
    "dist:mac": "electron-builder --mac dmg",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist release *.tsbuildinfo"
  },
  "build": {
    "appId": "dev.aiworkspace.desktop",
    "productName": "AI Workspace",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": "-",
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "AI Workspace"
    }
  },
  "devDependencies": {
    "@ai-workspace/protocol": "workspace:*",
    "@ai-workspace/transport": "workspace:*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.454.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "motion": "^12.42.2",
    "streamdown": "^2.5.0"
  }
}
