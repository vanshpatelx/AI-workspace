{
  "name": "@ai-workspace/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "aiw": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts worker start",
    "postinstall": "node scripts/fix-node-pty.mjs",
    "cli": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json && cp src/permission-hook.mjs dist/permission-hook.mjs && chmod +x dist/cli.js",
    "start": "node dist/cli.js worker start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ai-workspace/protocol": "workspace:*",
    "@ai-workspace/transport": "workspace:*",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
