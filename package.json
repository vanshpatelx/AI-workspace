{
  "name": "ai-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first desktop app for managing AI-powered development environments across machines.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Vansh Patel",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter \"./packages/*\" build",
    "dev": "pnpm build:packages && pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
